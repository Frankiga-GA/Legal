# =============================================================================
# LUSTI - Frontend environment template
# =============================================================================
# Copia este archivo como ".env" y completa SOLO con valores publicos.
# NINGUNA clave service_role o de Gemini debe terminar en este archivo.
# =============================================================================

# URL publica del backend documental (HTTPS en produccion)
VITE_DOCUMENT_BACKEND_URL=http://127.0.0.1:8000

# Supabase - claves publicables (anon/publishable key)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Google OAuth (Client ID publico de Google Cloud Console)
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Gemini NO deberia estar aqui en produccion. Si necesitas desarrollo
# local rapido, puedes usar una clave restringida por referer/dominio,
# pero la recomendacion es llamar al backend.
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
