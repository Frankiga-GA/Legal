# =============================================================================
# LUSTI - Backend environment template
# =============================================================================
# Copia este archivo como "backend/.env" y completa con los secretos.
# NUNCA lo commitees. .gitignore ya lo excluye.
# =============================================================================

# --- IA ------------------------------------------------------------------
# Clave privada de Google Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase (auth + DB) -----------------------------------------------
# URL del proyecto (https://xxxxx.supabase.co)
SUPABASE_URL=

# JWT secret: Dashboard -> Settings -> API -> JWT Secret
# Lo usa el backend para validar el Bearer token de cada request.
SUPABASE_JWT_SECRET=

# Service role key: SOLO para bypass de RLS en operaciones internas
# (audit log, validacion de roles, invitaciones). El frontend NUNCA
# debe verla.
SUPABASE_SERVICE_ROLE_KEY=

# --- HTTP / CORS --------------------------------------------------------
# Origenes permitidos para CORS (CSV). NO uses "*" en produccion.
ALLOWED_ORIGINS=http://localhost:5173,https://tu-dominio.com

# Puerto del backend
PORT=8000
